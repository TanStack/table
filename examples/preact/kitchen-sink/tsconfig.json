{
  "compilerOptions": {
    "strictNullChecks": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "skipLibCheck": true,
    "paths": {
      "react": ["./node_modules/preact/compat/"],
      "react-dom": ["./node_modules/preact/compat/"]
    }
  },
  "include": [
    "node_modules/vite/client.d.ts",
    "src/**/*",
    "vite.config.js",
    "vite.config.ts"
  ],
  "exclude": ["dist/**/*", "node_modules"]
}
